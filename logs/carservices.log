    -- ✅ NEW: price + currency from lmps_service (latest ACTIVE row)
    ls.price                   AS price,
    ls.currency                AS currency

FROM reservation_service_request r

JOIN branch b
  ON b.branch_id = r.branch_id

LEFT JOIN car_details cd
  ON cd.car_id = r.car_id

